                    '段类型': seg_type,
                    '段地址': addr_str,
                    '块地址': block_addr_str,
                    '状态': state,
                    '大小(格式化)': format_size(block_size),
                    '大小(字节)': block_size,
                    '真实大小(格式化)': format_size(real_size) if real_size > 0 else "N/A",
                    '真实大小(字节)': real_size if real_size > 0 else 0
                })

                print(f"      块 {j}:")
                print(f"        状态: {state}")
                print(f"        大小: {format_size(block_size)}")
                print(f"        地址: {block_addr_str}")
                if real_size > 0 and real_size != block_size:
                    print(f"        真实大小: {format_size(real_size)}")

                if state == 'inactive':
                    bubbles_data.append({
                        '段索引': i,
                        '块索引': j,
                        '段类型': seg_type,
                        '段地址': addr_str,
                        '块地址': block_addr_str,
                        '碎片大小(格式化)': format_size(block_size),
                        '碎片大小(字节)': block_size
                    })

        print("\n" + "=" * 80)
        print("内存段汇总")
        print("=" * 80)
        print(f"  总段数: {len(snapshot['segments'])}")
        print(f"  总保留(Reserved): {format_size(total_segment_size)}")
        print(f"  总已分配(Allocated): {format_size(total_allocated_size)}")
        print(f"  总活跃(Active): {format_size(total_active_size)}")
        print(f"  总碎片(Inactive): {format_size(total_inactive_size)}")
        print(f"  碎片率: {total_inactive_size / total_segment_size * 100:.2f}%")

    max_bubble_count = 0

    if 'device_traces' in snapshot:
        print("\n" + "=" * 80)
        print("设备跟踪(Device Traces)分析")
        print("=" * 80)

        traces_list = snapshot['device_traces']
        print(f"  跟踪列表长度: {len(traces_list)}")

        for device_idx, trace_entry in enumerate(traces_list):
            if not isinstance(trace_entry, list):
                continue

            events = trace_entry
            print(f"\n  事件数量: {len(events)}")

            print(f"\n    事件列表 (含碎片状态):")
            print(f"    {'序号':<6} {'类型':<18} {'地址':<20} {'大小':<12} {'碎片数':<8} {'碎片总大小':<12} {'reserved':<12} {'allocated':<12}")
            print(f"    {'-'*110}")

            bootstrap = compute_trace_bootstrap(snapshot, events)

            tracker = BubbleTracker()
            segments = list(bootstrap['segments'])
            seq = 0
            table_seq = 0

            for idx, event in enumerate(events):
                action = event.get('action', 'unknown')
                addr = event.get('addr', 0)
                size = event.get('size', 0)

                if action in ('segment_alloc', 'segment_map'):
                    segments.append((addr, size))
                elif action == 'segment_free':
                    segments[:] = [(a, s) for a, s in segments if not (a == addr and s == size)]

                effective_size = size
                if action == 'alloc':
                    effective_size = infer_alloc_block_size(addr, size, events, idx, segments)

                tracker.apply_event(action, addr, effective_size)

                running_reserved, running_allocated = simulate_memory_at_event(
                    snapshot, events, idx, device=device_idx,
                )

                stats = tracker.snapshot()
                max_bubble_count = max(max_bubble_count, stats['count'])

                display_action = normalize_action(action)
                if display_action:
                    table_seq += 1
                    bubble_table_data.append(
                        build_bubble_table_row(
                            table_seq, display_action, addr, size, stats,
                            running_reserved, running_allocated,
                        )
                    )

                seq += 1
                addr_str = format_addr(addr)
                print(
                    f"    {seq:<6} {action:<18} {addr_str:<20} "
                    f"{format_size(size):<12} {stats['count']:<8} {format_size(stats['total_size']):<12} "
                    f"{format_size(running_reserved):<12} {format_size(running_allocated):<12}"
                )

    print("\n" + "=" * 80)
    print("碎片详细分析 (最终快照状态)")
    print("=" * 80)

    if bubbles_data:
        bubbles_data.sort(key=lambda x: x['碎片大小(字节)'], reverse=True)

        print(f"\n  发现 {len(bubbles_data)} 个碎片:")
        for bubble in bubbles_data:
            print(f"    段{bubble['段索引']}块{bubble['块索引']}: {bubble['碎片大小(格式化)']}")
            print(f"      段类型: {bubble['段类型']}")
            print(f"      段地址: {bubble['段地址']}")
            print(f"      块地址: {bubble['块地址']}")

        print(f"\n  碎片大小分布:")
        size_buckets = {
            'tiny (<1KiB)': 0,
            'small (1KiB-1MiB)': 0,
            'medium (1MiB-10MiB)': 0,
            'large (10MiB+)': 0
        }
        for bubble in bubbles_data:
            size = bubble['碎片大小(字节)']
            if size < 1024:
                size_buckets['tiny (<1KiB)'] += 1
            elif size < 1024 * 1024:
                size_buckets['small (1KiB-1MiB)'] += 1
            elif size < 10 * 1024 * 1024:
                size_buckets['medium (1MiB-10MiB)'] += 1
            else:
                size_buckets['large (10MiB+)'] += 1

        for bucket, count in size_buckets.items():
            print(f"    {bucket}: {count} 个")

        largest_bubble = bubbles_data[0]
        print(f"\n  最大碎片: {largest_bubble['碎片大小(格式化)']} (段{largest_bubble['段索引']}块{largest_bubble['块索引']})")
        print(f"  最小碎片: {format_size(bubbles_data[-1]['碎片大小(字节)'])} (段{bubbles_data[-1]['段索引']}块{bubbles_data[-1]['块索引']})")
        avg_bubble_size = sum(b['碎片大小(字节)'] for b in bubbles_data) / len(bubbles_data)
        print(f"  平均碎片大小: {format_size(avg_bubble_size)}")

    else:
        print("  未发现碎片")

    print("\n" + "=" * 80)
    print(f"正在导出Excel: {output_file}")
    print("=" * 80)

    table_columns = build_bubble_table_columns(max_bubble_count)
    df_bubble_table = pd.DataFrame(bubble_table_data)

    if not df_bubble_table.empty:
        for col in table_columns:
            if col not in df_bubble_table.columns:
                df_bubble_table[col] = ''
        df_bubble_table = df_bubble_table[table_columns]

    if os.path.exists(output_file):
        try:
            os.remove(output_file)
        except PermissionError:
            print(f"警告: 无法删除旧文件 {output_file}，可能正在被其他程序打开")

    with pd.ExcelWriter(output_file, engine='openpyxl') as writer:
        df_bubble_table.to_excel(writer, sheet_name='碎片跟踪', index=False)

        for sheet_name in writer.sheets:
            worksheet = writer.sheets[sheet_name]
            for col in worksheet.columns:
                max_length = 0
                for cell in col:
                    if cell.value:
                        max_length = max(max_length, len(str(cell.value)))
                worksheet.column_dimensions[col[0].column_letter].width = min(max_length + 2, 50)

    print(f"\nExcel文件已生成: {output_file}")
    print(f"  工作表「碎片跟踪」共 {len(bubble_table_data)} 行")

if __name__ == "__main__":

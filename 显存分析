3.pickle文件解析显存碎片
导出后的pickle文件可以通过MindStudio Insight和docs.pytorch.org/memory_viz网站进行可视化分析，也可以通过以下脚本进行

显存中出现较多碎片时，统计显存碎片的大小和地址
segment_map会因显存的碎片空间不够alloc进行扩张，找到内联关系
通过以下脚本解析pickle文件，可以弥补网页可视化上的这些不足
import pickle
import os
import pandas as pd

def format_size(b):
    if b is None:
        return "N/A"
    if b < 1024:
        return f"{b} B"
    elif b < 1024 * 1024:
        return f"{b / 1024:.2f} KiB"
    else:
        return f"{b / (1024 * 1024):.2f} MiB"

def format_addr(addr):
    if isinstance(addr, int):
        return f"0x{addr:x}"
    return str(addr)

class BubbleTracker:
    """通过重放 allocator 事件，跟踪 inactive 碎片（空闲可复用块）。"""

    def __init__(self):
        self.bubbles = []

    @staticmethod
    def _merge(bubbles):
        if not bubbles:
            return []
        bubbles = sorted(bubbles, key=lambda x: x[0])
        merged = [bubbles[0]]
        for addr, size in bubbles[1:]:
            prev_addr, prev_size = merged[-1]
            if prev_addr + prev_size == addr:
                merged[-1] = (prev_addr, prev_size + size)
            else:
                merged.append((addr, size))
        return merged

    def _consume(self, addr, size):
        end = addr + size
        result = []
        for b_addr, b_size in self.bubbles:
            b_end = b_addr + b_size
            if b_end <= addr or b_addr >= end:
                result.append((b_addr, b_size))
            else:
                if b_addr < addr:
                    result.append((b_addr, addr - b_addr))
                if b_end > end:
                    result.append((end, b_end - end))
        self.bubbles = self._merge(result)

    def _add(self, addr, size):
        self.bubbles = self._merge(self.bubbles + [(addr, size)])

    def _remove_segment(self, seg_addr, seg_size):
        seg_end = seg_addr + seg_size
        result = []
        for b_addr, b_size in self.bubbles:
            b_end = b_addr + b_size
            if b_end <= seg_addr or b_addr >= seg_end:
                result.append((b_addr, b_size))
            else:
                if b_addr < seg_addr:
                    result.append((b_addr, seg_addr - b_addr))
                if b_end > seg_end:
                    result.append((seg_end, b_end - seg_end))
        self.bubbles = self._merge(result)

    def apply_event(self, action, addr, size):
        if action in ('segment_alloc', 'segment_map'):
            self._add(addr, size)
        elif action == 'alloc':
            self._consume(addr, size)
        elif action in ('free_completed', 'free'):
            self._add(addr, size)
        elif action == 'segment_free':
            self._remove_segment(addr, size)

    def snapshot(self):
        """按地址升序返回碎片，便于与内存图对齐。"""
        bubbles = sorted(self.bubbles, key=lambda x: x[0])
        total = sum(size for _, size in bubbles)
        max_size = max((size for _, size in bubbles), default=0)
        return {
            'count': len(bubbles),
            'total_size': total,
            'max_size': max_size,
            'bubbles': bubbles,
        }

ACTION_DISPLAY = {
    'segment_alloc': 'segment_map',
    'segment_map': 'segment_map',
    'alloc': 'alloc',
    'free_completed': 'free',
    'free': 'free',
}

def normalize_action(action):
    return ACTION_DISPLAY.get(action)

def find_segment_end(addr, segments):
    for seg_addr, seg_size in segments:
        if seg_addr <= addr < seg_addr + seg_size:
            return seg_addr + seg_size
    return None

def infer_alloc_block_size(addr, requested_size, events, cur_idx, segments):
    """PyTorch 按块对齐分配；用同 segment 内下一地址边界推断实际占用大小。"""
    seg_end = find_segment_end(addr, segments)
    next_addrs = []
    for e in events[cur_idx + 1:]:
        next_addr = e.get('addr', 0)
        if next_addr <= addr:
            continue
        if seg_end is not None and next_addr >= seg_end:
            continue
        if e.get('action') in ('alloc', 'free_completed', 'segment_alloc', 'segment_map'):
            next_addrs.append(next_addr)
    if next_addrs:
        block_size = min(next_addrs) - addr
        if block_size >= requested_size:
            return block_size
    return requested_size

def _seg_end(seg):
    return seg['addr'] + seg['size']

def _map_segment(segments, merge, seg):
    idx = next((i for i, s in enumerate(segments) if s['addr'] > seg['addr']), -1)
    if not merge:
        insert_at = len(segments) if idx == -1 else idx
        segments.insert(insert_at, dict(seg))
        return
    if idx == -1:
        idx = len(segments)
    segments.insert(idx, dict(seg))
    if idx + 1 < len(segments):
        nxt = segments[idx + 1]
        if _seg_end(seg) == nxt['addr'] and seg['stream'] == nxt['stream']:
            seg['size'] += nxt['size']
            segments.pop(idx + 1)
    if idx > 0:
        prev = segments[idx - 1]
        if _seg_end(prev) == seg['addr'] and prev['stream'] == seg['stream']:
            prev['size'] += seg['size']
            segments.pop(idx)

def _unmap_segment(segments, merge, seg):
    if not merge:
        segments[:] = [s for s in segments if s['addr'] != seg['addr']]
        return
    seg_end = _seg_end(seg)
    idx = next(
        i for i, s in enumerate(segments)
        if s['addr'] <= seg['addr'] and seg_end <= _seg_end(s)
    )
    existing = segments[idx]
    existing_end = _seg_end(existing)
    if existing['addr'] == seg['addr']:
        existing['addr'] += seg['size']
        existing['size'] -= seg['size']
        if existing['size'] == 0:
            segments.pop(idx)
    elif existing_end == seg_end:
        existing['size'] -= seg['size']
    else:
        existing['size'] = seg['addr'] - existing['addr']
        remainder = {
            'addr': seg_end,
            'size': existing_end - seg_end,
            'stream': existing['stream'],
        }
        segments.insert(idx + 1, remainder)

def build_memory_view_initial_state(snapshot, device=0):
    """从最终快照构建 memory_viz MemoryView 的初始 segments 与 block_map。"""
    segments = []
    block_map = {}
    for seg in snapshot.get('segments', []):
        if 'device' in seg and seg['device'] != device:
            continue
        segments.append({
            'addr': seg['address'],
            'size': seg['total_size'],
            'stream': seg.get('stream', 0),
        })
        for b in seg.get('blocks', []):
            state = b.get('state', '')
            if state not in ('active_allocated', 'active_pending_free', 'active_awaiting_free'):
                continue
            addr = b.get('address')
            block_map[addr] = {
                'addr': addr,
                'size': b.get('size', 0),
                'requested_size': b.get('requested_size', b.get('size', 0)),
                'free_requested': state in ('active_pending_free', 'active_awaiting_free'),
            }
    return segments, block_map

def simulate_memory_at_event(snapshot, events, idx, device=0):
    """
    与 memory_viz MemoryView.simulate_memory(idx) + draw(idx) 一致：
    从最终快照出发，撤销 idx 之后的 trace 事件，返回该操作执行后的 reserved/allocated。
    """
    init_segments, init_block_map = build_memory_view_initial_state(snapshot, device)
    l_segments = [dict(s) for s in init_segments]
    l_block_map = {k: dict(v) for k, v in init_block_map.items()}

    for i in range(len(events) - 1, idx, -1):
        event = events[i]
        action = event.get('action', '')
        addr = event.get('addr', 0)
        size = event.get('size', 0)
        stream = event.get('stream', 0)

        if action == 'free':
            l_block_map[addr] = {
                'addr': addr,
                'size': size,
                'requested_size': size,
                'free_requested': False,
            }
        elif action == 'free_requested':
            if addr in l_block_map:
                l_block_map[addr]['free_requested'] = False
        elif action == 'free_completed':
            l_block_map[addr] = {
                'addr': addr,
                'size': size,
                'requested_size': size,
                'free_requested': True,
            }
        elif action == 'alloc':
            l_block_map.pop(addr, None)
        elif action in ('segment_free', 'segment_unmap'):
            _map_segment(l_segments, action == 'segment_unmap', {
                'addr': addr, 'size': size, 'stream': stream,
            })
        elif action in ('segment_alloc', 'segment_map'):
            _unmap_segment(l_segments, action == 'segment_map', {
                'addr': addr, 'size': size, 'stream': stream,
            })

    reserved = sum(s['size'] for s in l_segments)
    allocated = sum(b['requested_size'] for b in l_block_map.values())
    return reserved, allocated

def bootstrap_segments_from_snapshot(snapshot, events):
    final = {(s.get('address'), s.get('total_size')) for s in snapshot.get('segments', [])}
    added = set()
    removed = set()
    for e in events:
        action = e.get('action')
        if action in ('segment_alloc', 'segment_map'):
            added.add((e.get('addr'), e.get('size')))
        elif action == 'segment_free':
            removed.add((e.get('addr'), e.get('size')))
    return list((final - added) | removed)

def compute_trace_bootstrap(snapshot, events):
    """碎片跟踪仍从 0 正向重放，需 baseline 补 history 启用前的 segment。"""
    final_segments = bootstrap_segments_from_snapshot(snapshot, events)
    return {'segments': final_segments}

def build_bubble_table_row(seq, display_action, addr, size, bubble_stats, reserved, allocated):
    row = {
        '序号': seq,
        '类型': display_action,
        '地址': format_addr(addr),
        '大小（格式化）': format_size(size),
        'reserved': format_size(reserved),
        'allocated': format_size(allocated),
        '碎片数量': bubble_stats['count'],
        '碎片总大小': format_size(bubble_stats['total_size']) if bubble_stats['count'] else '',
        '最大碎片大小': format_size(bubble_stats['max_size']) if bubble_stats['count'] else '',
    }
    for i, (b_addr, b_size) in enumerate(bubble_stats['bubbles'], start=1):
        row[f'碎片{i}大小'] = format_size(b_size)
        row[f'碎片{i}地址'] = format_addr(b_addr)
    return row

def build_bubble_table_columns(max_bubble_count):
    columns = [
        '序号', '类型', '地址', '大小（格式化）',
        'reserved', 'allocated',
        '碎片数量', '碎片总大小', '最大碎片大小',
    ]
    for i in range(1, max_bubble_count + 1):
        columns.extend([f'碎片{i}大小', f'碎片{i}地址'])
    return columns

